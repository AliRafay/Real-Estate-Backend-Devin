{
  "$schema": "http://json.schemastore.org/template",
  "author": "Koderlabs",
  "classifications": [
    "WebAPI",
    "Clean Architecture",
    "Boilerplate",
    "macOS",
    "Windows",
    "Cloud",
    "Web"
  ],
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "identity": "Demo.WebApi.Template",
  "name": "Demo Web API Template",
  "shortName": "kl-api",
  "sourceName": "Demo.WebApi",
  "preferNameDirectory": true,
  "sources": [
    {
      "source": "./",
      "target": "./",
      "exclude": [
        ".template.config/**",
        ".idea/**",
        ".vs/**",
        ".github/**",
        "media/**"
      ]
    }
  ],
  "primaryOutputs": [
    {
      "path": "./"
    }
  ],
  "postActions": [
    {
      "description": "Restore NuGet packages required by this project.",
      "manualInstructions": [
        {
          "text": "Run 'dotnet restore'"
        }
      ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ]
}
